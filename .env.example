# {{PROJECT_NAME}} — required env. Copy to .env locally (chmod 600 in prod).
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# DB (uncomment + populate when you add data layer)
# DATABASE_URL=postgres://user:pass@localhost:5432/{{PROJECT_NAME}}

# Auth
# JWT_ISSUER=
# JWT_AUDIENCE=
# JWT_SIGNING_KEY=

# S3-compatible object storage (optional). Cloudflare R2 in prod, MinIO locally.
# R2: S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL=

# Observability (logs only — banned SDKs enforced by CI)
LOG_LEVEL=Information
