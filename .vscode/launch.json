{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run {{PROJECT_NAME}}",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/{{PROJECT_NAME}}/bin/Debug/net10.0/{{PROJECT_NAME}}.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/{{PROJECT_NAME}}",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:8080"
      }
    },
    {
      "name": ".NET Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}
